# CloudOps-Platform — environment variables
# Copy to .env and adjust as needed.

# Paths to trained model artifacts (produced by model/train.py)
MODEL_PATH=model/artifacts/model.pkl
ENCODER_PATH=model/artifacts/encoder.pkl
METRICS_PATH=model/artifacts/metrics.json

# Where /predict appends live request logs (used for drift detection)
REQUEST_LOG=ops/data/live_requests.jsonl

# Drift job
BASELINE_PATH=model/artifacts/baseline_feature_freq.json
LIVE_LOG=ops/data/live_requests.jsonl
DRIFT_THRESHOLD=0.2

# Logging
LOG_LEVEL=INFO

# MLflow tracking server (docker compose service)
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=/mlruns
